{
    "name": "map2gltf",
    "version": "0.1.0",
    "description": "Quake .map (Valve 220) to glTF/GLB compiler",
    "license": "MIT",
    "type": "module",
    "main": "dist/compiler.js",
    "types": "dist/compiler.d.ts",
    "exports": {
        ".": {
            "import": "./dist/compiler.js",
            "types": "./dist/compiler.d.ts"
        }
    },
    "bin": {
        "map2gltf": "dist/index.js"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc",
        "build:web": "vite build web",
        "dev": "tsx src/index.ts",
        "dev:web": "vite dev web",
        "preview:web": "vite preview web",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint src tests web",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run build"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "@types/three": "^0.184.0",
        "@vitest/coverage-v8": "^2.1.9",
        "eslint": "^10.2.1",
        "happy-dom": "^20.9.0",
        "three": "^0.184.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.0",
        "vite": "^5.4.21",
        "vitest": "^2.1.9"
    },
    "dependencies": {
        "@gltf-transform/core": "^4.3.0"
    }
}
